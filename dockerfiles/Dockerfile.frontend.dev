# ============================================================================
# FinMind Frontend - Development Dockerfile
# ============================================================================
# For use with Tilt local K8s development
# Features: Vite HMR, live reload
# ============================================================================

FROM node:20-alpine

WORKDIR /app

# Install dependencies first (cache layer)
COPY package*.json ./
RUN npm ci

# Copy source
COPY . .

# Vite development server port
EXPOSE 5173

# Enable polling for Docker volume mounts
ENV CHOKIDAR_USEPOLLING=true
ENV WATCHPACK_POLLING=true

# Development command
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
